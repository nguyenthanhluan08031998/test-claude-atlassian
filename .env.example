# Anthropic API Key (Required)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Jira Configuration (Required)
# IMPORTANT: JIRA_BASE_URL should include the TARGET TICKET you want to work on
# Example: https://oneline.atlassian.net/browse/FCM-973
JIRA_BASE_URL=https://your-domain.atlassian.net/browse/YOUR-TICKET-123
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token

# Example User Story (Required)
# This ticket will be used as a style reference
# Example: https://oneline.atlassian.net/browse/FCM-3715
USER_STORY_LINK_EXAMPLE=https://your-domain.atlassian.net/browse/EXAMPLE-456
